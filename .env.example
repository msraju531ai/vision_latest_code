# ── Application ──
APP_NAME=VisionAI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./data/vision_ai.db

# ── Video Ingestion ──
FRAME_SAMPLE_INTERVAL=2
MAX_CONCURRENT_STREAMS=10
VIDEO_STORAGE_PATH=./data/videos
FRAME_STORAGE_PATH=./data/frames
DETECTION_IMAGES_PATH=./data/detections
RTSP_OPEN_RETRIES=3
RTSP_RETRY_DELAY_SECONDS=2.0
RTSP_TRANSPORT=auto
RTSP_TIMEOUT_SECONDS=10.0

# ── Video Recording ──
RECORD_VIDEO=true
RECORDING_PATH=./data/recordings
RECORDING_ARCHIVE_PATH=./data/recordings/archive
RECORDING_FPS=5

# ── YOLO Model ──
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_DEVICE=cpu

# ── Anomaly Detection ──
IDLE_THRESHOLD_SECONDS=300
UNAUTHORIZED_ZONE_ALERT=true
SHIFT_DEVIATION_THRESHOLD=0.3

# ── Alerts ──
ALERT_COOLDOWN_SECONDS=300
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme
ALERT_RECIPIENTS=manager@example.com

# ── OpenAI (for incident summaries) ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Face recognition (employee match). Raise to 0.65–0.7 if wrong person is labelled ──
FACE_MATCH_THRESHOLD=0.6
# If true, only employees on current shift are recognised; if false, all employees are matched (recognised people show as Authorised)
MATCH_ONLY_EMPLOYEES_ON_SHIFT=false

# ── On-Prem / GPU ──
USE_GPU=false
GPU_DEVICE_ID=0
